# Good Loop — environment

# Leave these unset to run on the in-memory mock data (default during development).
#
# Set both to point the app at a real Supabase project. When both are present,
# the app automatically uses the Supabase-backed data provider instead of the
# mock — no code changes. Copy this file to ".env.local" and fill in your values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Voice (TTS) — optional ------------------------------------------------
# The Sound Studio's voice track can synthesize real guidance. Pick ONE engine.
# With none set, the Studio still PREVIEWS with the browser voice, but can't
# render/layer/export voice. See docs/TTS_SETUP.md. NOTE: these keys ship to the
# browser — fine for a closed test, proxy them server-side for production.

# ElevenLabs (preferred — most natural pt-BR)
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=
# Optional second (male) voice — used by the [M] rows of the Deep
# double-induction; absent → those rows use the primary voice.
VITE_ELEVENLABS_VOICE_ID_M=

# Azure neural voices (e.g. pt-BR-FranciscaNeural, pt-BR-AntonioNeural)
VITE_AZURE_TTS_KEY=
VITE_AZURE_TTS_REGION=
VITE_AZURE_TTS_VOICE=


# ---- Interface language (i18n) ----------------------------------------------
# Default UI language when the user hasn't chosen one in Profile -> Language.
# One of: en | it | pt-BR   (users can always switch in-app; the choice persists
# per browser). For the Italian PO test deployment set:
VITE_DEFAULT_LOCALE=it
